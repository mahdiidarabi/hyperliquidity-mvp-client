# Copy to .env and set your key. Never commit .env.
PRIVATE_KEY=0x<your_key_here>

# Network: if HYPERLIQUID_API_URL is unset, HYPERLIQUID_MAINNET picks mainnet vs testnet (default mainnet).
# If HYPERLIQUID_API_URL is the official mainnet or testnet URL, signing uses the matching chain too.
# HYPERLIQUID_MAINNET=true
# HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
# HYPERLIQUID_API_URL=https://api.hyperliquid-testnet.xyz
