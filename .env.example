# Copy to .env and fill in. Never commit .env.

# --- Wallet (required) ---
PRIVATE_KEY=0x<your_key_here>

# --- Hyperliquid HTTP API (required: canonical hosts for signing + defaults) ---
# Active API (or leave unset to use MAINNET vs TESTNET URL from HYPERLIQUID_MAINNET below).
# HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_MAINNET_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_TESTNET_API_URL=https://api.hyperliquid-testnet.xyz
# When HYPERLIQUID_API_URL is unset: true = use MAINNET URL, false = use TESTNET URL.
HYPERLIQUID_MAINNET=true

# --- Documentation & deposit hints (required for wallet_info / deposit text) ---
HYPERLIQUID_DOCS_URL=https://hyperliquid.gitbook.io/hyperliquid-docs
DEPOSIT_USDC_LAYER2_NAME=Arbitrum One
DEPOSIT_ARBITRUM_CHAIN_ID=42161
# Optional overrides:
# DEPOSIT_LABEL_MAINNET=mainnet (production API)
# DEPOSIT_MAINNET_NOTE=...
# DEPOSIT_LABEL_TESTNET=testnet API
# DEPOSIT_TESTNET_LAYER2_HINT=...
# DEPOSIT_TESTNET_CHAIN_ID=N/A
# DEPOSIT_TESTNET_NOTE=...

# --- Django (optional) ---
# DJANGO_SECRET_KEY=
# DJANGO_SETTINGS_MODULE=config.settings

# --- Real money safety: required for `manage.py withdraw --execute` ---
# HYPERLIQUID_REAL_MONEY_ACK=I_UNDERSTAND
